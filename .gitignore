# ================================================
# ARCHIVOS SENSIBLES - NUNCA SUBIR A GITHUB
# ================================================

# Variables de entorno con contraseñas y tokens
.env

# Base de datos SQLite (contiene datos de pacientes)
*.db
*.sqlite
*.sqlite3

# ================================================
# ARCHIVOS DE PYTHON
# ================================================

# Carpetas de caché de Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Entornos virtuales
venv/
env/
.env/
.venv/

# Distribuciones y builds
dist/
build/
*.egg-info/
*.egg

# ================================================
# LOGS Y TEMPORALES
# ================================================

# Archivos de log
*.log
logs/

# Archivos temporales
*.tmp
*.temp
*.swp
*.swo
*~

# ================================================
# SISTEMA OPERATIVO
# ================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

# ================================================
# IDE Y EDITORES
# ================================================

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# PyCharm
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ================================================
# PLAYWRIGHT
# ================================================

# Capturas de pantalla y videos de test
test-results/
playwright-report/

# ================================================
# ARCHIVO DE ESTADO (opcional)
# ================================================

# Si creás un archivo para control de ejecución
*.pid
*.lock